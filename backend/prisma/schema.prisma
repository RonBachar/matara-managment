// Matara — initial schema for projects, briefs, and AI pipeline runs (PostgreSQL).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Work project; `clientName` is plain text only.
model Project {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String

  projectName String
  clientName  String
  status      String  @default("התחיל")

  totalAmount Decimal @default(0) @db.Decimal(14, 2)
  paidAmount  Decimal @default(0) @db.Decimal(14, 2)

  notes String? @db.Text

  @@index([userId])
}

/// A client/customer record with flat package metadata.
model Client {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String

  clientName   String
  businessName String @default("")
  phone        String @default("")
  email        String @default("")
  website      String?
  notes String? @db.Text

  packageType        String   @default("none")
  packagePrice       Decimal? @db.Decimal(14, 2)
  renewalDate        String?
  reminderDaysBefore Int?

  agreementFileId   String?
  agreementFileName String?
  agreementFileType String?

  @@index([clientName])
  @@index([userId])
}

/// Standalone questionnaire / brief content; flexible JSON until fields are normalized.
model ProjectBrief {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String

  title String @default("")

  /// Full brief payload (questionnaire answers, etc.).
  data Json @default("{}")

  pipelineRuns PipelineRun[]

  @@index([userId])
}

/// One execution of the AI pipeline for a given brief.
model PipelineRun {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  briefId String
  brief   ProjectBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)

  status PipelineRunStatus @default(PENDING)

  startedAt  DateTime?
  finishedAt DateTime?
  error      String? @db.Text

  steps PipelineStep[]

  @@index([briefId])
}

enum PipelineRunStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

/// A single step inside a pipeline run (ordering, I/O, status).
model PipelineStep {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  runId String
  run   PipelineRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  /// Sequence order (0, 1, 2, …).
  stepOrder Int
  /// Stable key for the step type, e.g. "sitemap", "copy".
  stepKey   String

  status PipelineStepStatus @default(PENDING)

  inputJson  Json?
  outputJson Json?
  error      String? @db.Text

  @@index([runId])
}

enum PipelineStepStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  SKIPPED
}

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String

  clientName String
  phone      String  @default("")
  email      String?
  leadSource String  @default("")
  status     String  @default("חדש")
  notes      String? @db.Text

  @@index([userId])
}

model Task {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String

  title       String
  description String? @db.Text
  status      String  @default("לביצוע")
  priority    String  @default("בינונית")

  @@index([userId])
}
