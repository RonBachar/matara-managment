# Used by Prisma CLI and the Express app (Supabase)

# Transaction-mode pooler (runtime queries)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&sslmode=require"

# Session-mode pooler (migrations / introspection)
DIRECT_URL="postgresql://user:password@host:5432/postgres?sslmode=require"

ALLOWED_ORIGINS=http://localhost:5173

# FIREBASE_SERVICE_ACCOUNT_JSON=<paste full JSON on one line for production hosting>

# Static secret for POST /api/webhooks/leads (header: X-Matara-Webhook-Secret)
MATARA_WEBHOOK_SECRET=change-me-to-a-random-32-char-string

# Firebase UID of the sole MATARA user; webhook-created leads are assigned to this user
MATARA_OWNER_USER_ID=your-firebase-uid-here
